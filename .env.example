# ──────────────────────────────────────────────────────────────────────────
# Infinity Outreach Agent — environment configuration
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ──────────────────────────────────────────────────────────────────────────

APP_NAME=Infinity Outreach Agent

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/outreach.sqlite

# ── Local LLM (Ollama, OpenAI-compatible endpoint) ─────────────────────────
# Hermes / OpenClaw agents run a local model. Point this at your Ollama server.
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=hermes3
# Dummy key — Ollama ignores it but the OpenAI client requires a non-empty value.
OLLAMA_API_KEY=ollama

# ── Sending behaviour ──────────────────────────────────────────────────────
# EMAIL_MODE:
#   draft        -> generate drafts only, never send automatically (safest)
#   review       -> only send drafts you (or the agent) explicitly approved
#   auto_send    -> send freshly generated drafts automatically (use carefully)
EMAIL_MODE=review
REQUIRE_HUMAN_APPROVAL=true

# Max emails to send per calendar day. Gmail caps: ~500/day (free), ~2000/day
# (Workspace). Keep below your cap. You asked for up to 1000 — that suits a
# Google Workspace ("company") account. New accounts should ramp up slowly.
DAILY_SEND_LIMIT=200

# Seconds to pause between individual sends (polite pacing, looks human).
SEND_DELAY_SECONDS=20

# ── Discovery (Google Places API — the supported way to query Google Maps) ──
# Enable the "Places API" in Google Cloud and paste the key here.
GOOGLE_PLACES_API_KEY=
# SEARCH_PROVIDER: google_places | manual_csv
SEARCH_PROVIDER=google_places
# Max Google Places API calls per day (Text Search Pro = $17/1k calls).
# 300/day × 30 days × $0.017 = ~$153/month — safely under the $200 free credit.
# At ~10 calls/city this gives ~30 cities/day. Raise carefully if you need more.
PLACES_DAILY_LIMIT=300

# ── Website enrichment (polite scraping of public pages only) ──────────────
REQUEST_TIMEOUT=15
REQUEST_DELAY_SECONDS=2
USER_AGENT=InfinityOutreachBot/0.2 (+https://infinityfaith.example; contact: hello@infinityfaith.example)

# ── Outbound mailbox (your Google / company mail) ──────────────────────────
# For Gmail / Google Workspace use an APP PASSWORD (Account > Security >
# App passwords), NOT your normal password. Leave blank until ready to send.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# Identity shown on outgoing mail and used in the email body.
SENDER_NAME=Infinity Faith Team
SENDER_EMAIL=
SENDER_ORG=Infinity Faith
APP_URL=https://infinityfaith.example

# ── Opt-out inbox scanner (optional, IMAP) ─────────────────────────────────
# If set, the agent can scan replies for "unsubscribe"/"stop" and auto-add
# senders to the suppression list. Leave blank to disable.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
