# ──────────────────────────────────────────────────────────────────────────
# Infinity Outreach Agent — environment configuration
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ──────────────────────────────────────────────────────────────────────────

APP_NAME=Infinity Outreach Agent

# ═══════════════════════════════════════════════════════════════════════════
#  SET THESE IN VS CODE — this is your whole configuration.
# ═══════════════════════════════════════════════════════════════════════════

# ── Your sending mailbox (Gmail / Google Workspace) ────────────────────────
# Use an APP PASSWORD, NOT your normal password:
#   Google Account → Security → 2-Step Verification → App passwords
SMTP_USER=john.doe@gmail.com
SMTP_PASSWORD=your-app-password-here
SENDER_NAME=John Doe
SENDER_EMAIL=john.doe@gmail.com

# ── The email ──────────────────────────────────────────────────────────────
# The BODY comes from email_templates/outreach_en.html (+ outreach_<lang>.html
# for native versions). Only the subject lives here. {{org_name}} works here too.
EMAIL_SUBJECT=An invitation to try Infinity Faith

# ── Sending policy ─────────────────────────────────────────────────────────
# EMAIL_MODE:
#   draft      -> DRY RUN. Discovers + drafts but SENDS NOTHING. (start here)
#   auto_send  -> LIVE. Sends drafts automatically within the daily limit.
#   review     -> only sends drafts an operator approved in the panel.
# Inspect a few drafts in the panel, then switch to auto_send to go live.
EMAIL_MODE=draft

# Max emails per calendar day (the CEILING). Gmail free ~500/day, Workspace
# ~2000/day. New domains should warm up (below) rather than start high.
DAILY_SEND_LIMIT=200
# Seconds between individual sends (polite pacing, looks human).
SEND_DELAY_SECONDS=20

# Automatic domain warm-up (recommended for a new sending domain). When on, the
# effective daily limit ramps from WARMUP_START up to DAILY_SEND_LIMIT, multiplying
# by WARMUP_MULTIPLIER every WARMUP_EVERY_DAYS days. Anchored to your first send
# (or pin it with WARMUP_START_DATE=YYYY-MM-DD).
WARMUP_ENABLED=false
WARMUP_START=50
WARMUP_MULTIPLIER=1.25
WARMUP_EVERY_DAYS=3

# ── Discovery: Google Places API key (PRIMARY source) ──────────────────────
# Google Places is the primary source (best coverage). OpenStreetMap (free, no
# key) is the FALLBACK used once the daily Google budget below is reached — so
# discovery keeps running for free after the cap. Leave blank to run OSM-only.
GOOGLE_PLACES_API_KEY=
# Hard cap on Google calls/day (Text Search Pro ≈ $17/1k). 300/day ≈ $153/mo,
# under the $200 free credit. OSM takes over for free once this cap is hit.
PLACES_DAILY_LIMIT=300

# ── Autonomous loop (`cli auto`) ───────────────────────────────────────────
AUTO_CYCLE_SECONDS=60      # pause between pipeline cycles
AUTO_DISCOVER_BATCH=3      # cities discovered per cycle

# ── Opt-out inbox scanner (OPTIONAL, IMAP) ─────────────────────────────────
# If set, replies containing "unsubscribe"/"stop" auto-add the sender to the
# suppression list. Leave blank to disable.
IMAP_USER=
IMAP_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════
#  Defaults below — you normally do NOT need to touch these.
# ═══════════════════════════════════════════════════════════════════════════

DATABASE_URL=sqlite:///data/outreach.sqlite

SMTP_HOST=smtp.gmail.com
# 587 = STARTTLS (recommended — works through more firewalls/antivirus than 465/SSL).
SMTP_PORT=587

IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# Polite scraping of public org websites (email enrichment).
REQUEST_TIMEOUT=15
REQUEST_DELAY_SECONDS=2
USER_AGENT=InfinityOutreachBot/0.2 (+https://infinityfaith.example; contact: hello@infinityfaith.example)

# Email templates folder (one outreach_<lang>.html per language; en is required).
EMAIL_TEMPLATE_DIR=email_templates
